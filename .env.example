# ─── Redroom Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit a populated .env file to version control.
#
# Variables prefixed with VITE_ are bundled into the client-side JavaScript
# and are visible to end users. Do NOT place private secrets in VITE_ variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass12345@localhost:5432/redroom

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# ── CMS Super-Admin ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=replace_with_a_strong_random_secret

# ── OAuth (User Authentication) ───────────────────────────────────────────────
VITE_APP_ID=your_oauth_app_id
OAUTH_SERVER_URL=https://your-oauth-provider.example.com
VITE_OAUTH_PORTAL_URL=https://your-oauth-login-portal.example.com

# ── LLM / AI Service (Server-side — NEVER expose to client) ──────────────────
BUILT_IN_FORGE_API_URL=https://your-llm-api.example.com
BUILT_IN_FORGE_API_KEY=your_server_side_llm_api_key

# ── LLM / AI Service (Client-side — public-safe scope only) ──────────────────
VITE_FRONTEND_FORGE_API_URL=https://your-llm-api.example.com
VITE_FRONTEND_FORGE_API_KEY=your_client_side_llm_api_key

# ── AIS Vessel Tracking ───────────────────────────────────────────────────────
AIS_API_KEY=your_ais_api_key

# ── Application Metadata ──────────────────────────────────────────────────────
VITE_APP_TITLE=Redroom
VITE_APP_LOGO=https://redroom.live/logo.png

# ── Owner Identity (for system notifications) ─────────────────────────────────
OWNER_OPEN_ID=your_oauth_open_id
OWNER_NAME=Your Name

# ── Analytics (optional) ──────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=https://your-analytics.example.com/api/send
VITE_ANALYTICS_WEBSITE_ID=your_analytics_website_id
